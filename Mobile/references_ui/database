    mo_ta NVARCHAR(MAX),
    thoi_gian DATETIME,
    dia_diem NVARCHAR(500),
    chi_bo_to_chuc_id INT NULL,
    so_nguoi_tham_gia INT DEFAULT 0,
    trang_thai NVARCHAR(50) DEFAULT N'dang_mo_dang_ky', -- dang_mo_dang_ky, da_dong, dang_dien_ra, hoan_thanh, huy
    is_deleted BIT DEFAULT 0,
    deleted_at DATETIME NULL,
    deleted_by INT NULL,
    created_at DATETIME DEFAULT GETDATE(),
    updated_at DATETIME DEFAULT GETDATE(),
    CONSTRAINT FK_VolunteerActivity_Cell FOREIGN KEY (chi_bo_to_chuc_id) 
        REFERENCES party_cells(id)
);
GO

-- =============================================
-- 14. Bảng Đăng ký hoạt động (Activity Registrations)
-- =============================================
CREATE TABLE activity_registrations (
    id INT IDENTITY(1,1) PRIMARY KEY,
    hoat_dong_id INT NOT NULL,
    dang_vien_id INT NOT NULL,
    trang_thai_dang_ky NVARCHAR(50) DEFAULT N'da_dang_ky', -- da_dang_ky, da_huy, da_duyet
    diem_danh NVARCHAR(50), -- co_mat, vang
    is_deleted BIT DEFAULT 0,
    deleted_at DATETIME NULL,
    deleted_by INT NULL,
    created_at DATETIME DEFAULT GETDATE(),
    updated_at DATETIME DEFAULT GETDATE(),
    CONSTRAINT FK_ActivityReg_Activity FOREIGN KEY (hoat_dong_id) 
        REFERENCES volunteer_activities(id),
    CONSTRAINT FK_ActivityReg_Member FOREIGN KEY (dang_vien_id) 
        REFERENCES party_members(id)
);
GO

-- =============================================
-- 15. Bảng Lịch sử thay đổi (Audit Logs)
-- =============================================
